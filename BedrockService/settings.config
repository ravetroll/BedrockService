<settings>
  <BackupConfig>
    <BackupOn>false</BackupOn>
    <BackupIntervalCron>0 1 * * *</BackupIntervalCron>    <!-- See https://crontab.guru/ for assistance in how to write cron strings-->
    <!-- Tiered retention (restic/borg style). A backup is kept if any rule wants it;
         everything else is pruned. With every rule off (as below), or the whole <Retention>
         block omitted, every backup is kept - nothing is ever deleted.
         KeepWithin accepts m/h/d/w (e.g. 2h, 7d); the rest count distinct periods. 0 = rule off. -->
    <Retention>
      <KeepWithin></KeepWithin>
      <KeepLast>0</KeepLast>
      <KeepHourly>0</KeepHourly>
      <KeepDaily>0</KeepDaily>
      <KeepWeekly>0</KeepWeekly>
      <KeepMonthly>0</KeepMonthly>
      <KeepYearly>0</KeepYearly>
    </Retention>
  </BackupConfig>
  <ServerConfig>
    <BedrockServerExeLocation>C:\Program Files (x86)\Bedrock\BedrockServer\bedrock_server.exe</BedrockServerExeLocation>
    <WCFPortNumber>19134</WCFPortNumber>
    <BackupFolderName>BedrockServiceBackup</BackupFolderName>
    <StartupCommands>
      <CommandText>
        help 1
      </CommandText>
      <CommandText>
        help 2
      </CommandText>
    </StartupCommands>
  </ServerConfig>
</settings>
